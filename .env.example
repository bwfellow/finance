# ============================================
# Convex Backend Configuration
# ============================================
# Choose ONE of the two options below:

# --- Option A: Self-Hosted Convex (local Docker) ---
# CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
# CONVEX_SELF_HOSTED_ADMIN_KEY=<generated by: docker compose exec backend ./generate_admin_key.sh>

# --- Option B: Convex Cloud ---
# These are auto-populated when you run `npx convex dev` and log in:
# CONVEX_DEPLOYMENT=dev:<your-project-name>

# ============================================
# Frontend (Vite)
# ============================================
# For self-hosted: use your local backend URL
# For Convex cloud: use your deployment URL (e.g. https://<project>.convex.cloud)
VITE_CONVEX_URL=http://127.0.0.1:3210

# ============================================
# Plaid Integration (Optional)
# ============================================
# Get these from https://dashboard.plaid.com/developers/keys
# Set via Convex dashboard or `npx convex env set`
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
